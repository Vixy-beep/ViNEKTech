# -----------------------------------------------------------------------------
# Django core
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-this-to-a-strong-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,vinektech.com,www.vinektech.com
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://vinektech.com,https://www.vinektech.com
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_ADMIN_ALLOWED_IPS=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Use one of these:
# 1) DATABASE_URL for production
# 2) POSTGRES_* for local/manual PostgreSQL setup
DATABASE_URL=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
USD_TO_DOP_RATE=62

# -----------------------------------------------------------------------------
# Email / SMTP
# -----------------------------------------------------------------------------
# For local development you can keep the console backend.
# For production, change to SMTP and fill the values below.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@vinektech.com
REPORT_EMAIL_TO=

# -----------------------------------------------------------------------------
# Optional extras
# -----------------------------------------------------------------------------
# Leave blank unless you specifically need them.
SENTRY_DSN=
GOOGLE_ANALYTICS_ID=
